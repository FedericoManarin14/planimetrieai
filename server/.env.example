# Copia in .env e inserisci la tua chiave. Mai committare .env.
# Chiave OpenRouter (una sola chiave, tanti modelli): https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
# Modello opzionale (default: google/gemini-2.5-flash)
# Es. alternativi: google/gemini-2.5-pro, anthropic/claude-sonnet-4.5, openai/gpt-4o
# OPENROUTER_MODEL=google/gemini-2.5-flash
# PORT=8787
